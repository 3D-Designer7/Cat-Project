# =============================================================
# CatChat — Environment Variables
# Copy this file to .env.local for local development
# Set these in your Vercel project dashboard for production
# =============================================================

# ── Supabase ─────────────────────────────────────────────────
# Your Supabase project URL and anonymous public key
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://exalqemsksybzschzibp.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_n4y-_oseQEu579QpfCzx8w_Ad1ixt7w"

# ── Signaling Server ──────────────────────────────────────────
# The URL of your self-hosted Socket.io signaling server.
#
# LOCAL DEV: Leave empty — the app connects to the same origin
#            (both Next.js and Socket.io run together via `npm run dev`)
#
# PRODUCTION: Set this to your server's public IP + port
#   Examples:
#     http://123.45.67.89:3000        ← Home PC / VPS with public IP
#     http://your-domain.com:3000     ← If you have a domain
#
# ⚠️  Port 3000 must be open on your server/router.
#     See signaling-server-setup.md for router port-forwarding guide.
NEXT_PUBLIC_SIGNALING_URL=""

# ── Redis (Optional) ──────────────────────────────────────────
# Only needed if running multiple signaling server instances (scaling).
# Leave empty to use in-memory queues (fine for a single server).
REDIS_URL=""

# ── Gemini AI (Optional) ──────────────────────────────────────
# Only needed if using AI features.
GEMINI_API_KEY=""
